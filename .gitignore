cat > .gitignore <<'EOF'
# Python virtual environments
.venv/
bin/
include/
lib/
lib64
pyvenv.cfg

# Python generated files
__pycache__/
*.py[cod]

# Node / Svelte
node_modules/
dist/
dist-ssr/
.svelte-kit/

# Environment and local configuration
.env
.env.*
!.env.example
*.local

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Local source data
data.json
*:Zone.Identifier

# Editors and OS
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
EOF
